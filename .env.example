# Agent Router Platform — environment configuration.
# Copy to `.env` (docker compose reads it automatically) and edit the secrets.
#   cp .env.example .env

# ---- Host ----
# Host port the frontend (nginx) is published on. Open http://localhost:<HTTP_PORT>.
HTTP_PORT=8080

# ---- PostgreSQL ----
# Used by the postgres container AND by the backend to build its DSN.
# The backend connects to host "postgres" (the compose service name) on 5432;
# config.go assembles host=postgres port=5432 user=... password=... dbname=...
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_router
POSTGRES_SSLMODE=disable

# ---- Redis ----
# The backend reaches Redis at the compose service name "redis" on 6379.
# (REDIS_ADDR is set to redis:6379 inside docker-compose.yml.)
REDIS_PASSWORD=
REDIS_DB=0

# ---- Secrets (REQUIRED) ----
# JWT_SECRET signs admin JWTs (HS256). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# SECRET_KEY encrypts stored channel upstream keys (AES-256-GCM).
# Any length works: the server derives a 32-byte AES-256 key from it via SHA-256.
# Still, use a long random secret in production.
SECRET_KEY=change-me-to-a-long-random-string

# ---- Backend behaviour ----
# release | debug | test
GIN_MODE=release

# ---- Optional bootstrap admin ----
# If BOTH are set, an admin user is seeded on first start. Leave blank to
# instead create the first admin by registering through the web UI
# (the first account ever registered becomes admin).
ADMIN_USERNAME=
ADMIN_PASSWORD=
